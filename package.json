{
  "name": "understory",
  "version": "0.1.0",
  "private": true,
  "description": "LLM-managed knowledge base following the OKF spec — MCP server + web UI",
  "scripts": {
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "dev": "pnpm --parallel -r dev",
    "agent:query": "pnpm --filter @understory/core agent:query",
    "agent:mutate": "pnpm --filter @understory/core agent:mutate"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.15.0"
}
