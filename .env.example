# Environment variables are a local fallback. Prefer Agentos-managed secrets:
# agents secrets set GITHUB_APP_ID
# agents secrets set GITHUB_PRIVATE_KEY
# agents secrets set GITHUB_WEBHOOK_SECRET
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=
PORT=3000
LOG_LEVEL=info
DARK_FACTORY_WORKSPACE_ROOT=../workspace-darkfactory/managed-repository

# GitHub Actions managed sync secrets use these names, mapped from Agentos Manager secrets:
# DARK_FACTORY_APP_ID=
# DARK_FACTORY_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Managed repositories must also define CODEX_AUTH_JSON as a repository secret
# for Codex Review to approve pull requests.
